# 이 파일을 .env로 복사한 후 실제 값을 입력하세요
# .env 파일은 절대 Git에 커밋하지 마세요

# Google Gemini API 키 (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# 카카오워크 Incoming Webhook URL
# 카카오워크 관리자 페이지 → 앱스토어 → Incoming Webhook → 관리자전용톡방 대상으로 생성
KAKAOWORK_WEBHOOK_URL=https://api.kakaowork.com/v1/inbound/xxxxx

# nenovaweb.com 로그인 정보
NENOVAWEB_URL=https://nenovaweb.com
NENOVAWEB_USERNAME=
NENOVAWEB_PASSWORD=

# 카카오톡 Ctrl+S 저장 기본 폴더
KAKAO_SAVE_DIR=C:/Users/USER/Documents/KakaoTalk Downloads

# MOYI Kakao connector
MOYI_SERVER=https://api.nowlink.kr
MOYI_API_BASE=
MOYI_BRIDGE_SECRET=
MOYI_WORKSPACE_ID=
MOYI_AGENT_ID=nenova-owner-pc
# Exact room titles only. JSON array or comma-separated values are supported.
MOYI_ROOM_ALLOWLIST=
MOYI_AUTO_DISCOVER_ROOMS=1
MOYI_ROOM_SCAN_INTERVAL_SEC=900
MOYI_INBOUND_ENABLED=1
MOYI_WORKER_POLL_SEC=5
MOYI_MONITOR_POLL_SEC=5
