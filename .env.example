# 이 파일을 .env로 복사한 후 실제 값을 입력하세요
# .env 파일은 절대 Git에 커밋하지 마세요

# Google Gemini API 키 (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# 카카오워크 Incoming Webhook URL
# 카카오워크 관리자 페이지 → 앱스토어 → Incoming Webhook → 관리자전용톡방 대상으로 생성
KAKAOWORK_WEBHOOK_URL=https://api.kakaowork.com/v1/inbound/xxxxx

# nenovaweb.com 로그인 정보
NENOVAWEB_URL=https://nenovaweb.com
NENOVAWEB_USERNAME=
NENOVAWEB_PASSWORD=

# 카카오톡 Ctrl+S 저장 기본 폴더
KAKAO_SAVE_DIR=C:/Users/USER/Documents/KakaoTalk Downloads

# ── MOYI(talkhub) 브릿지 (시크릿만 .env, 모드 스위치는 런처 bat) ──
# 프로덕션 API base (기본 https://api.nowlink.kr)
TALKHUB_BASE_URL=https://api.nowlink.kr
# inbound/ensure-room/outbound 인증 헤더값 — talkhub 백엔드 BRIDGE_SECRET 과 동일 값
TALKHUB_BRIDGE_SECRET=
# (참고) 모드 스위치는 start_monitor_talkhub.bat 가 설정:
#   MIRROR_TARGET=talkhub|both|kakaowork|none, TALKHUB_MIRROR_ENABLED=1,
#   REVERSE_RELAY=0(거래처 발송 킬스위치), TALKHUB_SELF_LABEL=MOYI
