  "context_rules": {
    "_doc": "문맥 기반 분류 규칙 (단일 메시지로 분류 불가능한 경우)",
    "photo_context": {
      "description": "사진 메시지는 다음 텍스트 메시지와 묶어서 분류",
      "rule": "사진/사진 N장 → 바로 다음 같은 발신자 메시지가 설명",
      "example": "[사진 17장] + [13차 수국 불량] = DEFECT_REPORT"
    },
    "multi_line_message": {
      "description": "여러 줄 메시지는 하나의 이벤트",
      "rule": "같은 발신자의 연속 메시지 중 시각이 1분 이내면 하나의 이벤트",
      "example": "[14-1 카네이션 불량] + [\\n주광] + [\\n연그린 1단] = 하나의 DEFECT_REPORT"
    },
    "thread_tracking": {
      "description": "같은 차수+품목 조합은 하나의 스레드",
      "rule": "차수+품목이 같으면 시간순으로 하나의 주문 스레드로 묶음",
      "lifecycle": "ORDER_NEW → ORDER_CHANGE_* → SHIP_* → DEFECT_* → COMM_CONFIRM"
    },
    "room_context": {
      "description": "방 이름이 분류 힌트를 제공",
      "mapping": {
        "수입방": "기본: ORDER (발주 문의/변경 중심)",
        "영업방팀 발주 및 추가 재고확인": "기본: ORDER_CHANGE (변경사항 위주)",
        "현장 추가취소방": "기본: ORDER_CHANGE (추가/취소 위주)",
        "현장단체방": "기본: SHIPMENT (출고/현장 위주)",
        "네노바 수입(불량 공유방)": "기본: DEFECT (불량 보고 위주)",
        "견적방": "기본: FINANCE (정산/계산서 위주)",
        "한국방역": "기본: LOGISTICS/LOG_QUARANTINE",
        "전산테스트팀": "기본: SYSTEM",
        "백상": "기본: LOGISTICS (물류/보관)",
        "빌번호및 입고수량확인방": "기본: LOGISTICS/LOG_BL"
      }
    }
  },
  "algorithm": {
    "_doc": "분류 알고리즘 실행 순서",
    "steps": [
      {
        "step": 1,
        "name": "전처리",
        "actions": [
          "카톡 메시지 패턴 파싱: [발신자] [시각] 내용",
          "연속 메시지 병합 (같은 발신자, 1분 이내)",
          "사진+설명 병합"
        ]
      },
      {
        "step": 2,
        "name": "구조 추출",
        "actions": [
          "차수 추출 (regex)",
          "품목+품종 추출 (known list + regex)",
          "수량+단위 추출 (regex)",
          "거래처 추출 (known list, 줄 위치 힌트)",
          "금액 추출 (regex)",
          "원산지 추출 (known list)"
        ]
      },
      {
        "step": 3,
        "name": "대분류 결정",
        "actions": [
          "키워드 매칭 (우선순위: DEFECT > ORDER > FINANCE > SHIPMENT > INVENTORY > LOGISTICS > SYSTEM > COMMS)",
          "방 컨텍스트 가중치 적용",
          "사진만 있으면 COMM_PHOTO (다음 메시지 대기)"
        ]
      },
      {
        "step": 4,
        "name": "중분류 결정",
        "actions": [
          "대분류 내 세부 키워드 매칭",
          "문맥 규칙 적용 (이전 메시지 참조)",
          "추출된 구조 데이터로 보정 (수량이 있으면 ORDER_CHANGE_ADD 등)"
        ]
      },
      {
        "step": 5,
        "name": "스레드 연결",
        "actions": [
          "차수+품목 조합으로 기존 스레드 매칭",
          "없으면 새 스레드 생성",
          "스레드 내 이벤트 순서 기록 (라이프사이클 추적)"
        ]
      },
      {
        "step": 6,
        "name": "품질 검증",
        "actions": [
          "미분류(COMMS만 남은) 비율 모니터링",
          "추출된 품목이 known list에 없으면 신규 품목 후보로 기록",
          "분류 결과를 구글시트에 기록 + 관리자 수정 피드백 학습"
        ]
      }
    ]
  }
}