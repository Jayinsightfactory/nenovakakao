  "extraction_rules": {
    "_doc": "메시지에서 구조화 데이터 추출 규칙",
    "sequence": {
      "description": "차수 추출 (화훼 수입 차수)",
      "patterns": [
        "(?P<main>\\d{1,2})[-/](?P<sub>\\d{1,2})\\s*차?",
        "(?P<main>\\d{1,2})차"
      ],
      "examples": [
        "14-1",
        "15-2차",
        "14차",
        "13-1"
      ]
    },
